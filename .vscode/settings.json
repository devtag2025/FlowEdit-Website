{
  // ============================================
  // FONT & APPEARANCE
  // ============================================
  "editor.fontFamily": "'Fira Code Retina', 'Fira Code', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.lineHeight": 1.6,
  "editor.fontWeight": "600",
  "editor.letterSpacing": 0.5,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",

  // Enable cursive italics for specific tokens
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["comment", "comment.block", "comment.line"],
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "keyword.control",
          "keyword.operator.new",
          "keyword.operator.expression",
          "keyword.operator.cast",
          "keyword.operator.sizeof",
          "storage.type.function.arrow",
          "keyword"
        ],
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": ["entity.other.attribute-name", "variable.parameter", "variable.language.this"],
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },

  // ============================================
  // EDITOR BEHAVIOR
  // ============================================
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.smoothScrolling": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,

  // ============================================
  // CODE ACTIONS & FORMATTING
  // ============================================
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // ============================================
  // AUTOCOMPLETE & SUGGESTIONS
  // ============================================
  "editor.suggestSelection": "first",
  "editor.suggest.showIcons": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.preview": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },

  // ============================================
  // FILES
  // ============================================
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true
  },

  // ============================================
  // TYPESCRIPT & JAVASCRIPT
  // ============================================
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "relative",
  "javascript.preferences.importModuleSpecifier": "relative",

  // ============================================
  // ESLINT
  // ============================================
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.format.enable": true,

  // ============================================
  // PRETTIER
  // ============================================
  "prettier.requireConfig": true,
  "prettier.singleQuote": true,
  "prettier.semi": false,
  "prettier.trailingComma": "es5",
  "prettier.printWidth": 80,

  // ============================================
  // TERMINAL
  // ============================================
  "terminal.integrated.fontFamily": "'Fira Code Retina', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontLigatures": true,
  "terminal.integrated.cursorBlinking": true,

  // ============================================
  // WORKBENCH
  // ============================================

  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "newUntitledFile",
  "workbench.list.smoothScrolling": true,

  // ============================================
  // EMMET
  // ============================================
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "emmet.triggerExpansionOnTab": true
}
